{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-antigravity-auth@latest"],
  "autoupdate": "notify",
  "permission": {
    "external_directory": {
      "*": "ask",
      "/tmp/**": "allow",
      "~/.config/opencode/**": "allow"
    }
  },
  "agent": {
    // default opencode models with customizations
    "build": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh"
    },
    "plan": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
      "permission": {
        "edit": {
          "*": "deny",
          "AGENTS.md": "allow",
          "**/AGENTS.md": "allow",
          ".opencode/plans/**": "allow"
        }
      }
    },
    "explore": {
      "model": "openai/gpt-5-nano",
      "permission": {
        "skill": "allow" // denied by default in opencode
      }
    },
    "general": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    // custom agents
    "quick": {
      "description": "Optimized for speed, this agent provides fast responses with a focus on efficiency. Ideal for simple tasks and quick interactions where response time is critical.",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "variant": "low",
      "permission": {
        "todoread": "deny",
        "todowrite": "deny"
      }
    },
    "deep": {
      "description": "Designed for complex problem-solving, this agent takes more time to analyze and generate responses. It excels at handling intricate tasks that require deeper reasoning and understanding.",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
      "permission": {
        "todoread": "deny",
        "todowrite": "deny"
      }
    },
    "frontend-expert": {
      "description": "Specialized in frontend development, this agent is trained to assist with tasks related to HTML, CSS, JavaScript, and popular frontend frameworks. It can provide code snippets, debug issues, and offer best practices for frontend development.",
      "mode": "all",
      "model": "google/antigravity-gemini-3.1-pro",
      "variant": "high"
    },
    // utility agents
    "summary": {
      "model": "opencode/big-pickle"
    },
    "title": {
      "model": "opencode/big-pickle"
    },
    "compaction": {
      "model": "google/antigravity-gemini-3-flash"
    }
  },
  "lsp": {
    "biome": {
      "command": ["biome", "lsp-proxy"],
      "extensions": [
        ".ts",
        ".tsx",
        ".mts",
        ".cts",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".json",
        ".jsonc",
        ".css",
        ".html"
      ]
    }
  },
  "formatter": {
    "stylua": {
      "command": [
        "stylua",
        "--search-parent-directories",
        "--stdin-filepath",
        "$FILE"
      ],
      "extensions": [".lua", ".luau"]
    },
    "markdownlint-cli2": {
      "command": ["markdownlint-cli2", "--fix", "$FILE"],
      "extensions": [".md", ".mdx"]
    }
  },
  "provider": {
    "google": {
      "name": "Google",
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "low": { "thinkingLevel": "low" },
            "high": { "thinkingLevel": "high" }
          }
        },
        "antigravity-gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro (Antigravity)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "low": { "thinkingLevel": "low" },
            "high": { "thinkingLevel": "high" }
          }
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "minimal": { "thinkingLevel": "minimal" },
            "low": { "thinkingLevel": "low" },
            "medium": { "thinkingLevel": "medium" },
            "high": { "thinkingLevel": "high" }
          }
        },
        "antigravity-claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Antigravity)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "antigravity-claude-opus-4-6-thinking": {
          "name": "Claude Opus 4.6 Thinking (Antigravity)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "low": { "thinkingConfig": { "thinkingBudget": 8192 } },
            "max": { "thinkingConfig": { "thinkingBudget": 32768 } }
          }
        },
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3-pro-preview": {
          "name": "Gemini 3 Pro Preview (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3.1-pro-preview-customtools": {
          "name": "Gemini 3.1 Pro Preview Custom Tools (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "username": "Ian"
}
